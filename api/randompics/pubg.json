const express = require("express");
const axios = require("axios");

const router = express.Router();

const API = "https://raw.githubusercontent.com/arulzzzxd/database/main/randompics/pubg.json";

let cachedData = null;
async function loadData() {
  try {
    const { data } = await axios.get(API, {
      headers: {
        "User-Agent": "Mozilla/5.0",
        Accept: "application/json"
      }
    });
    if (Array.isArray(data)) {
      cachedData = data;
    }
  } catch (err) {
    console.error("Gagal memuat data awal pubg:", err.message);
  }
}
loadData();

router.get("/", async (req, res) => {
  try {
    if (!cachedData) {
      await loadData();
    }

    if (!cachedData || !cachedData.length) {
      return res.status(404).json({
        status: false,
        creator: "ArulzXD",
        message: "Data tidak ditemukan atau gagal dimuat"
      });
    }

    const random = cachedData[Math.floor(Math.random() * cachedData.length)];

    const image = await axios.get(random.url, {
      responseType: "stream",
      headers: {
        "User-Agent": "Mozilla/5.0"
      }
    });

    res.setHeader(
      "Content-Type",
      image.headers["content-type"] || "image/jpeg"
    );

    image.data.pipe(res);

  } catch (e) {
    res.status(500).json({
      status: false,
      creator: "ArulzXD",
      message: e.message
    });
  }
});

router.status = "ready";
router.type = "free";
module.exports = router;
