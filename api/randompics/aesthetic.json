const express = require("express");
const axios = require("axios");

const router = express.Router();

const API = "https://raw.githubusercontent.com/arulzzzxd/database/main/randompics/aesthetic.json";

// Variabel lokal untuk menyimpan cache data agar tidak fetch ulang setiap request
let cachedData = null;

// Fungsi helper untuk mengambil data dengan fallback/safety
async function getDatabase() {
  if (cachedData && cachedData.length > 0) {
    return cachedData;
  }
  
  try {
    const { data } = await axios.get(API, {
      headers: {
        "User-Agent": "Mozilla/5.0",
        Accept: "application/json"
      }
    });
    
    if (Array.isArray(data) && data.length > 0) {
      cachedData = data; // Simpan ke cache jika sukses
      return cachedData;
    }
    return [];
  } catch (error) {
    console.error("Gagal memuat database dari GitHub:", error.message);
    // Jika gagal tetapi sebelumnya sudah ada cache, pakai cache lama
    return cachedData || []; 
  }
}

router.get("/", async (req, res) => {
  try {
    const data = await getDatabase();

    if (!data.length) {
      return res.status(404).json({
        status: false,
        creator: "ArulzXD",
        message: "Data database kosong atau tidak ditemukan"
      });
    }

    // Memilih gambar secara acak dari cache
    const random = data[Math.floor(Math.random() * data.length)];

    // Mengirim hasil langsung sebagai gambar (Stream)
    const image = await axios.get(random.url, {
      responseType: "stream",
      headers: {
        "User-Agent": "Mozilla/5.0"
      }
    });

    res.setHeader(
      "Content-Type",
      image.headers["content-type"] || "image/jpeg"
    );

    image.data.pipe(res);

  } catch (e) {
    res.status(500).json({
      status: false,
      creator: "ArulzXD",
      message: e.message
    });
  }
});

router.status = "ready";
router.type = "free";
module.exports = router;
