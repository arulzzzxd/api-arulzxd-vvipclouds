const axios = require('axios');
const express = require('express');
const router = express.Router();

// Fungsi untuk mengambil gambar Aesthetic secara acak
async function aesthetic() {
    try {
        // 1. Ambil data JSON yang berisi list URL gambar
        const { data } = await axios.get('https://raw.githubusercontent.com/arulzzzxd/database/main/randompics/aesthetic.json');
        
        // Pastikan data berupa array, jika data berbentuk object/string silakan sesuaikan parser-nya
        const imageUrls = Array.isArray(data) ? data : JSON.parse(data);
        
        // 2. Pilih salah satu URL secara acak
        const randomUrl = imageUrls[Math.floor(Math.random() * imageUrls.length)];
        
        // 3. Ambil gambar dari URL acak tersebut sebagai arraybuffer
        const response = await axios.get(randomUrl, { responseType: 'arraybuffer' });
        
        // Mengembalikan object berisi buffer gambar dan content-type nya secara dinamis (png/jpg/jpeg)
        return {
            buffer: Buffer.from(response.data),
            contentType: response.headers['content-type'] || 'image/jpeg' // default ke jpeg jika tidak terdeteksi
        };
    } catch (error) {
        throw error;
    }
}

// Endpoint utama Router
router.get('/', async (req, res) => {
    try {
        const image = await aesthetic();
        
        // Mengirimkan response berupa gambar langsung ke browser
        res.writeHead(200, {
            'Content-Type': image.contentType,
            'Content-Length': image.buffer.length,
        });
        res.end(image.buffer);
    } catch (error) {
        return res.status(500).json({ error: error.message });
    }
});

router.status = "ready"; 
router.type = "free";
module.exports = router;
